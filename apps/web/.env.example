# ─── IndiLingo Frontend Environment Variables ─────────────────────────────
# Copy this file to .env.local for local development.
# For Netlify: set these in Site settings → Environment variables.
# ──────────────────────────────────────────────────────────────────────────

# URL of the deployed Express API server.
# Leave empty in Replit (the proxy routes /api calls automatically).
# Required for Netlify / standalone deployments.
# Example: https://indilingo-api.onrender.com
VITE_API_URL=
