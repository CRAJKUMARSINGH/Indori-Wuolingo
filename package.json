{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "echo preinstall skipped",
    "dev": "pnpm --parallel --filter @indilingo/web --filter @indilingo/api-server --filter @workspace/indori-wuolingo run dev",
    "dev:web": "pnpm --filter @indilingo/web run dev",
    "dev:api": "pnpm --filter @indilingo/api-server run dev",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --filter \"./packages/**\" --if-present run typecheck",
    "seed": "tsx packages/curriculum/src/seed-db.ts",
    "test:robotic": "pnpm --filter @indilingo/robotic-tests run test",
    "serve": "pnpm --filter @workspace/indori-wuolingo run serve"
  },
  "private": true,
  "dependencies": {
    "serverless-http": "^4.0.0"
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "typescript": "~5.9.3"
  }
}
