# ─────────────────────────────────────────────────────────────────────────────
# Indori-Wuolingo — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. This file (.env.example) is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Local dev:   postgresql://postgres:postgres@localhost:5432/indori_wuolingo
# Neon (prod): postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# Supabase:    postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/indori_wuolingo

# ── Auth / Sessions ───────────────────────────────────────────────────────────
# JWT signing secret. Use a random 64-char string in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# ── API Server ────────────────────────────────────────────────────────────────
# Port the Express server listens on locally. Netlify ignores this (uses functions).
PORT=3001

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. If empty, CORS is disabled.
# Example: CORS_ORIGIN=https://indori-wuolingo.vercel.app,http://localhost:5173
CORS_ORIGIN=

# ── Web Frontend (Vite) ───────────────────────────────────────────────────────
# Base path for the Vite app. Keep as "/" for root deployments.
BASE_PATH=/

# ── Expo / Mobile ─────────────────────────────────────────────────────────────
# Required by Expo Router when running outside of Replit.
# Set to your local machine's LAN IP or tunnel domain during mobile dev.
# Example: EXPO_PUBLIC_DOMAIN=192.168.1.10:8081
EXPO_PUBLIC_DOMAIN=

# ── Netlify (set these in the Netlify dashboard, NOT here) ───────────────────
# DATABASE_URL  → Site settings → Environment variables
# SESSION_SECRET → Site settings → Environment variables
# Do not set Netlify-specific values in this file.

# ── Optional: Analytics & Monitoring ─────────────────────────────────────────
# PostHog project API key (client-side, safe to expose)
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_POSTHOG_HOST=https://app.posthog.com

# Sentry DSN for crash reporting (client-side, safe to expose)
# VITE_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
